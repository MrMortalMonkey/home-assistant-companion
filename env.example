# ═══ Home Assistant AI Companion — Configuration ═══
# Copy this file to .env and fill in the values.
# The install.sh wizard can generate it interactively for you.

# ─── REQUIRED ───

# Telegram Bot (created via @BotFather → /newbot)
TELEGRAM_TOKEN=

# Home Assistant
HA_URL=http://192.168.1.XX:8123
HA_TOKEN=

# ─── LLM PROVIDER CONFIGURATION ───
# Supported providers: anthropic, openai, openrouter, ollama, lmstudio
LLM_PROVIDER=anthropic

# API Keys (only needed for the selected provider)
ANTHROPIC_API_KEY=                # For LLM_PROVIDER=anthropic
OPENAI_API_KEY=                   # For LLM_PROVIDER=openai
OPENROUTER_API_KEY=               # For LLM_PROVIDER=openrouter
OLLAMA_HOST=http://localhost:11434  # For LLM_PROVIDER=ollama
LMSTUDIO_HOST=http://localhost:1234 # For LLM_PROVIDER=lmstudio

# -- Optional: Override default models for the selected provider --
# For OpenRouter, use model IDs such as openai/gpt-4o-mini or anthropic/claude-3.5-haiku.
LLM_MODEL=
LLM_MODEL_STRONG=

# ─── OPTIONAL ───

# Optional internal monthly API budget in USD. 0 disables the internal cap.
# Prefer provider-side key limits when available.
LLM_MONTHLY_BUDGET_USD=0

# Security method for the 6-digit code at startup
# Possible values: free_mobile | ha_notify | email
SMS_METHOD=ha_notify

# Free Mobile SMS (only if SMS_METHOD=free_mobile)
FREE_MOBILE_USER=
FREE_MOBILE_PASS=

# SMTP Email (only if SMS_METHOD=email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_DEST=

# ─── ADVANCED: Beta tester mode (opt-in) ───
# Enables deploy_server to receive remote patches.
# DO NOT ENABLE unless you want automatic updates from MrMortalMonkey.
# See docs/BETA_CHANNEL.md for security implications.
ENABLE_DEPLOY_SERVER=false
